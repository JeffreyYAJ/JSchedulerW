{
	
  "name": "JWScheduler-desktop",
	
  "version": "1.0.0",
	
  "main": "main.js",
	
  "scripts": {
	
  	
  "start:backend": "cd JSchedulerW_backend && npm start",
	
  	
  "start:frontend": "cd JSchedulerW_frontend && npm run dev",
	
  	
  "start:electron": "wait-on http://localhost:5173 && electron . --no-sandbox",
	
  	
  "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\""
	
  },
	
  "devDependencies": {
	
  	
  "electron": "^40.8.0",
	
  	
  "electron-is-dev": "^3.0.1"
	
  },
	
  "dependencies": {
	
  	
  "concurrently": "^9.2.1",
	
  	
  "wait-on": "^9.0.4"
	
  }
}
